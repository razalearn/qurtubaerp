{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3.0",
        "ext-curl": "*",
        "awobaz/compoships": "^2.4",
        "barryvdh/laravel-dompdf": "^3.1",
        "dacoto/laravel-wizard-installer": "dev-main",
        "doctrine/dbal": "^3.8",
        "google/apiclient": "^2.18",
        "guzzlehttp/guzzle": "^7.8",
        "intervention/image": "^3.11",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.0",
        "maatwebsite/excel": "^3.1",
        "mahesh-kerai/update-generator": "^2.1",
        "razorpay/razorpay": "^2.9",
        "spatie/laravel-permission": "^6.0",
        "stripe/stripe-php": "^18.0",
        "unicodeveloper/laravel-paystack": "dev-l12-compatibility"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/laravel-shift/laravel-paystack.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/wrteam-sagar/laravel-wizard-installer.git"
        }
    ],
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/notification_helper.php",
            "app/Helpers/settings_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "pre-autoload-dump": "Google\\Task\\Composer::cleanup",
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "*"
            ],
            "discover": [
                "spatie/laravel-permission"
            ]
        },
        "google/apiclient-services": [
            "FirebaseCloudMessaging"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "platform-check": false
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
